{
  "name": "테스트 플로우",
  "workflow_definition": {
    "name": "테스트 플로우",
    "nodes": [
      {
        "id": "node-1",
        "name": "Start",
        "type": "n8n-nodes-base.manualTrigger",
        "parameters": {},
        "position": [100, 300]
      },
      {
        "id": "node-2",
        "name": "SetUserInfo",
        "type": "n8n-nodes-base.set",
        "parameters": {
          "values": {
            "string": [
              {
                "name": "greeting",
                "value": "={{ \"안녕하세요, \" + $json.name + \"님!\" }}"
              },
              {
                "name": "email",
                "value": "={{ $json.email }}"
              }
            ],
            "number": [
              {
                "name": "score",
                "value": "={{ $json.score }}"
              }
            ]
          }
        },
        "position": [300, 300]
      },
      {
        "id": "node-3",
        "name": "CheckScore",
        "type": "n8n-nodes-base.if",
        "parameters": {
          "conditions": {
            "number": [
              {
                "value1": "={{ $json.score }}",
                "operation": "largerEqual",
                "value2": 80
              }
            ]
          }
        },
        "position": [500, 300]
      },
      {
        "id": "node-4",
        "name": "CallAPI",
        "type": "n8n-nodes-base.httpRequest",
        "parameters": {
          "method": "GET",
          "url": "https://httpbin.org/get",
          "queryParametersUi": {
            "parameter": [
              {
                "name": "greeting",
                "value": "={{ $json.greeting }}"
              }
            ]
          }
        },
        "position": [700, 200]
      },
      {
        "id": "node-5",
        "name": "LowScorePass",
        "type": "n8n-nodes-base.noOp",
        "parameters": {},
        "position": [700, 400]
      }
    ],
    "connections": {
      "Start": {
        "main": [
          [{"node": "SetUserInfo", "type": "main", "index": 0}]
        ]
      },
      "SetUserInfo": {
        "main": [
          [{"node": "CheckScore", "type": "main", "index": 0}]
        ]
      },
      "CheckScore": {
        "main": [
          [{"node": "CallAPI",      "type": "main", "index": 0}],
          [{"node": "LowScorePass", "type": "main", "index": 0}]
        ]
      }
    }
  }
}
